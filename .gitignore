# ─── Klucze API i sekrety ─────────────────────────────────────────────────────
# Klucze w tej aplikacji są przechowywane w SharedPreferences (na urządzeniu),
# NIE w kodzie. Poniższe wpisy zabezpieczają na wypadek, gdybyś podczas
# developmentu stworzył lokalny plik z kluczami.

.env
.env.*
*.env
env.dart
secrets.dart
